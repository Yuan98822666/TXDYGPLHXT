# ============================================================
# TXDYGPLHXT 环境变量配置
# ============================================================
# 复制此文件为 .env 后填写实际值
# 配置加载优先级：环境变量 > .env 文件 > 默认值
# ============================================================

# ==============================
# 数据库配置（必填）
# ==============================
# PostgreSQL 主机地址
POSTGRES_HOST=localhost

# PostgreSQL 端口
POSTGRES_PORT=5432

# 数据库名称
POSTGRES_DB=TXDYGPLHXT

# 数据库用户名
POSTGRES_USER=postgres

# 数据库密码（敏感信息）
POSTGRES_PASSWORD=your_password_here

# ==============================
# SQLAlchemy 连接池配置
# ==============================
# 是否输出 SQL 日志（开发环境 True，生产环境 False）
DB_ECHO=False

# 连接池大小
DB_POOL_SIZE=10

# 最大溢出连接数
DB_MAX_OVERFLOW=20

# ==============================
# 应用配置
# ==============================
# 应用环境：dev / test / prod
APP_ENV=dev
